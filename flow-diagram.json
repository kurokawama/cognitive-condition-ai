  "flows": [
    {
      "id": "flow_onboarding",
      "role": "guest",
      "name": "初回オンボーディングフロー",
      "description": "アプリ初回起動→説明→登録→初回チェックまでの一連の導線",
      "priority": "critical",
      "steps": [
        { "step": 1, "page": "onboarding", "action": "「始める」をタップ", "element": "btn_start", "expected_result": "オンボーディング説明画面に遷移" },
        { "step": 2, "page": "signup", "action": "メール・パスワード・年代を入力して登録", "element": "form_signup", "expected_result": "アカウント作成成功" },
        { "step": 3, "page": "home", "action": "ホーム画面が表示される", "element": "btn_start_check", "expected_result": "「今日のチェックを始める」ボタンが目立つ位置に表示" }
      ],
      "edge_cases": [
        { "name": "メール重複", "condition": "既存メールで登録", "expected": "エラーメッセージ表示、ログインリンク提示" }
      ]
    },
    {
      "id": "flow_daily_check",
      "role": "free_user",
      "name": "日次チェックフロー",
      "description": "ホーム→チェック開始→3テスト→結果表示→ひとこと記録の一連の導線",
      "priority": "critical",
      "steps": [
        { "step": 1, "page": "home", "action": "「今日のチェックを始める」をタップ", "element": "btn_start_check", "expected_result": "チェック画面に遷移" },
        { "step": 2, "page": "check", "action": "反応速度テスト実行（5-7試行）", "element": "btn_reaction", "expected_result": "テスト完了、次のテストへ自動遷移" },
        { "step": 3, "page": "check", "action": "短期記憶テスト実行", "element": "btn_memory", "expected_result": "テスト完了、次のテストへ自動遷移" },
        { "step": 4, "page": "check", "action": "注意切替テスト実行（30-45秒）", "element": "btn_attention", "expected_result": "テスト完了、結果画面へ遷移" },
        { "step": 5, "page": "check_result", "action": "結果確認：総合スコア・サブスコア・前日比", "element": "data_total_score", "expected_result": "スコアが表示される" },
        { "step": 6, "page": "check_result", "action": "ひとこと記録（睡眠・気分・忙しさ）", "element": "btn_hitokoto_result", "expected_result": "記録モーダルが開き、1タップで記録できる" }
      ],
      "edge_cases": [
        { "name": "テスト中断", "condition": "アプリがバックグラウンドに移動", "expected": "テストが一時停止し、復帰時に再開" },
        { "name": "2回目のチェック", "condition": "同日に2回目のチェックを実施", "expected": "2回目の結果が記録され、今日の最高スコアを表示" }
      ]
    },
    {
      "id": "flow_premium_analysis",
      "role": "premium_user",
      "name": "有料AI分析フロー",
      "description": "チェック結果→AI分析→AIトークの一連の導線",
      "priority": "high",
      "steps": [
        { "step": 1, "page": "check_result", "action": "「詳しく見る」をタップ", "element": "btn_to_analysis", "expected_result": "AI分析画面に遷移" },
        { "step": 2, "page": "analysis", "action": "今日の傾向・原因仮説・行動提案を確認", "element": "data_hypothesis", "expected_result": "断定せず仮説で表示される" },
        { "step": 3, "page": "ai_talk", "action": "AIトークで対話", "element": "form_chat", "expected_result": "1-3往復の対話が行われる" }
      ],
      "edge_cases": [
        { "name": "データ不足", "condition": "初日の分析", "expected": "「まだデータが少ないですが」と前置きして仮説を提示" }
      ]
    },
    {
      "id": "flow_free_to_premium",
      "role": "free_user",
      "name": "無料→有料アップグレードフロー",
      "description": "無料ユーザーがAI分析プレビューから課金画面に遷移する導線",
      "priority": "high",
      "steps": [
        { "step": 1, "page": "check_result", "action": "「詳しく見る」をタップ", "element": "btn_to_analysis", "expected_result": "プレビュー画面に遷移" },
        { "step": 2, "page": "analysis_preview", "action": "プレビュー（ぼかし）を確認", "element": "data_preview", "expected_result": "分析のぼかしプレビューが表示される" },
        { "step": 3, "page": "analysis_preview", "action": "「詳しく見る（プレミアム）」をタップ", "element": "btn_upgrade", "expected_result": "課金画面に遷移" },
        { "step": 4, "page": "subscription", "action": "月額 or 年額を選択", "element": "btn_subscribe_monthly", "expected_result": "課金処理完了→プレミアムに昇格" }
      ],
      "edge_cases": []
    },
    {
      "id": "flow_notification_setup",
      "role": "free_user",
      "name": "通知設定フロー",
      "description": "通知のON/OFF・時刻設定",
      "priority": "medium",
      "steps": [
        { "step": 1, "page": "notification_settings", "action": "通知ON/OFF切替", "element": "form_notif", "expected_result": "通知設定が切り替わる" },
        { "step": 2, "page": "notification_settings", "action": "時刻・頻度設定", "element": "form_notif", "expected_result": "設定が保存される" }
      ],
      "edge_cases": [
        { "name": "通知権限拒否", "condition": "OSレベルで通知権限が拒否されている", "expected": "設定画面へのリンクを提示" }
      ]
    }
  ],

